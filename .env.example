# Database (Supabase)
# Transaction Pooler (port 6543) — runtime connections
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Direct Connection (port 5432) — migrations & introspection
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].supabase.com:5432/postgres

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true

# Google OAuth (also used for Google Business Profile API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth (Graph API for Page reviews)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Google Places API (Competitor tracking)
GOOGLE_PLACES_API_KEY=

# Yelp Fusion API
YELP_API_KEY=

# WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Stripe (Payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Anthropic API (AI features)
ANTHROPIC_API_KEY=

# Resend (Email)
RESEND_API_KEY=

# Cron Secret (Vercel Cron authorization)
CRON_SECRET=

# Feature Flags
FEATURE_BETA_INVITE=false
NEXT_PUBLIC_FEATURE_BETA_INVITE=false
FEATURE_FEEDBACK=true
NEXT_PUBLIC_FEATURE_FEEDBACK=true

# Sentry (Error Monitoring)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
